{
  "name": "@j3r3mcdev/lib-waf-blf",
  "version": "1.0.23",
  "description": "Advanced modular WAF library with detectors, pipeline, providers and multi-framework middleware.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/j3r3mcdev/lib-waf.git"
  },
  "homepage": "https://github.com/j3r3mcdev/lib-waf#readme",
  "bugs": {
    "url": "https://github.com/j3r3mcdev/lib-waf/issues"
  },
  "publishConfig": {
    "@j3r3mcdev:registry": "https://npm.pkg.github.com"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsc",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "lint": "eslint . --ext .ts",
    "sanity": "node sanity-check.cjs",
    "sanity:lite": "node sanity-check.cjs --no-git",
    "prepush": "npm run sanity:lite",
    "prepare": "husky",
    "release:patch": "npm version patch && npm run sanity:lite && git push --follow-tags && npm publish"
  },
  "keywords": [
    "waf",
    "security",
    "middleware",
    "typescript",
    "cybersecurity",
    "detectors",
    "pipeline"
  ],
  "author": "Jérémy",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "29.5.14",
    "@types/maxmind": "^2.0.5",
    "@types/node": "^26.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "husky": "^9.1.7",
    "jest": "29.7.0",
    "rimraf": "^5.0.5",
    "ts-jest": "29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "5.3.3"
  },
  "dependencies": {
    "ip2location-nodejs": "^9.8.0"
  }
}
